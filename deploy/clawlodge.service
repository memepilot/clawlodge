[Unit]
Description=ClawLodge Next.js App
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/clawlodge
Environment=NODE_ENV=production
Environment=PORT=3001
Environment=CLAWLODGE_DATA_DIR=/var/lib/clawlodge
EnvironmentFile=/var/www/clawlodge/.env.production
ExecStart=/var/www/clawlodge/node_modules/.bin/next start -p 3001
Restart=always
RestartSec=5
TimeoutStopSec=20
KillMode=control-group

[Install]
WantedBy=multi-user.target
